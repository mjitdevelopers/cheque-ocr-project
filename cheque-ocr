# app_debug.py
import tkinter as tk
from tkinter import messagebox
import sys
import os
import traceback

# Write debug info to file
with open('debug_log.txt', 'w', encoding='utf-8') as f:
    f.write("="*50 + "\n")
    f.write("DEBUG INFORMATION\n")
    f.write("="*50 + "\n")
    f.write(f"Python Version: {sys.version}\n")
    f.write(f"Python Executable: {sys.executable}\n")
    f.write(f"Running as EXE: {getattr(sys, 'frozen', False)}\n")
    f.write(f"Current Directory: {os.getcwd()}\n")
    f.write(f"Script Directory: {os.path.dirname(os.path.abspath(__file__))}\n")
    f.write("\nSYSTEM PATH:\n")
    f.write(f"PATH: {os.environ.get('PATH', 'Not set')}\n")
    
    f.write("\n" + "="*50 + "\n")
    f.write("TRYING TO IMPORT PADDLEOCR\n")
    f.write("="*50 + "\n")
    
    try:
        f.write("Step 1: Importing paddleocr module...\n")
        import paddleocr
        f.write(f"✅ PaddleOCR module found at: {paddleocr.__file__}\n")
        f.write(f"PaddleOCR version: {getattr(paddleocr, '__version__', 'unknown')}\n")
        
        f.write("\nStep 2: Setting environment variables...\n")
        os.environ['KMP_DUPLICATE_LIB_OK'] = 'TRUE'
        os.environ['FLAGS_logtostderr'] = '0'
        os.environ['GLOG_minloglevel'] = '2'
        f.write("✅ Environment variables set\n")
        
        f.write("\nStep 3: Importing PaddleOCR class...\n")
        from paddleocr import PaddleOCR
        f.write("✅ PaddleOCR class imported\n")
        
        f.write("\nStep 4: Initializing PaddleOCR...\n")
        f.write("This may take a few seconds...\n")
        
        ocr = PaddleOCR(
            use_angle_cls=False, 
            show_log=False, 
            lang='en',
            det_db_thresh=0.3,
            det_db_box_thresh=0.2
        )
        f.write("✅ PaddleOCR initialized successfully!\n")
        
        f.write("\nStep 5: Testing with a simple inference...\n")
        f.write("Creating a small test...\n")
        OCR_AVAILABLE = True
        
    except ImportError as e:
        OCR_AVAILABLE = False
        f.write(f"\n❌ Import Error: {str(e)}\n")
        f.write("\nFull traceback:\n")
        traceback.print_exc(file=f)
        
    except Exception as e:
        OCR_AVAILABLE = False
        f.write(f"\n❌ Initialization Error: {str(e)}\n")
        f.write("\nFull traceback:\n")
        traceback.print_exc(file=f)

# Create simple GUI
root = tk.Tk()
root.title("OCR Debug Tool")
root.geometry("500x400")
root.resizable(False, False)

# Title
tk.Label(root, text="OCR Debug Information", font=("Arial", 14, "bold")).pack(pady=10)

# Status
status_frame = tk.Frame(root)
status_frame.pack(pady=10)

if OCR_AVAILABLE:
    tk.Label(status_frame, text="✅ OCR IS WORKING!", fg="green", font=("Arial", 12, "bold")).pack()
else:
    tk.Label(status_frame, text="❌ OCR IS NOT WORKING", fg="red", font=("Arial", 12, "bold")).pack()

# Info button
def show_log():
    try:
        with open('debug_log.txt', 'r') as f:
            content = f.read()
            messagebox.showinfo("Debug Log", content)
    except:
        messagebox.showerror("Error", "Could not read debug_log.txt")

tk.Button(root, text="Show Debug Log", command=show_log, bg="blue", fg="white").pack(pady=10)

# Instructions
text_frame = tk.Frame(root)
text_frame.pack(pady=10, fill='both', expand=True)

text_widget = tk.Text(text_frame, height=15, width=60, wrap=tk.WORD)
text_widget.pack(side=tk.LEFT, fill='both', expand=True)

scrollbar = tk.Scrollbar(text_frame, command=text_widget.yview)
scrollbar.pack(side=tk.RIGHT, fill=tk.Y)
text_widget.config(yscrollcommand=scrollbar.set)

# Load debug log into text widget
try:
    with open('debug_log.txt', 'r') as f:
        text_widget.insert('1.0', f.read())
except:
    text_widget.insert('1.0', "Debug log not found. Run the application first.")

text_widget.config(state='disabled')

# Exit button
tk.Button(root, text="Exit", command=sys.exit, bg="red", fg="white").pack(pady=10)

root.mainloop()